{
  "name": "learnix",
  "version": "1.0.0",
  "description": "A Full-Stack AI Learning Assistant App using MERN stack (MongoDB, Express, React, Node.js), styled with Tailwind CSS, and powered by local LLMs via @xenova/transformers.",
  "main": "backend/server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "install-all": "npm install && npm install --prefix frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "start": "node backend/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "pdf-parse": "^1.1.1",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^7.3.1",
    "@types/multer": "^2.0.0",
    "nodemon": "^3.1.14"
  }
}